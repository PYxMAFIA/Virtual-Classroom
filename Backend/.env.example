# ==========================================
# Backend Environment Variables
# ==========================================
# Copy this file to .env and fill in your real credentials

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection String
mongoURL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# JWT Secret Key (any random string, use a strong random value in production)
SECRET_KEY=your_jwt_secret_here

# Super Admin Email (gets elevated privileges on login)
SUPER_ADMIN=your_super_admin_email@example.com

# Contact email shown to unverified users
CONTACT=your_contact_email@example.com

# Frontend URL (for generating meeting links)
FRONTEND_URL=http://localhost:5173

# Allowed Origins for CORS (comma-separated origins)
# In production, replace with your actual frontend domain
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# VideoSDK API Credentials (for video meetings)
# Get from: https://app.videosdk.live/
VIDEOSDK_API_KEY=your_videosdk_api_key
VIDEOSDK_SECRET=your_videosdk_secret

# Google Gemini AI API Key
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Gemini Model (optional, defaults to gemini-2.0-flash-exp)
GEMINI_MODEL=gemini-2.0-flash-exp

# Google OAuth Configuration (for Google Sign-In)
GOOGLE_CLIENT_ID=your_google_client_id

# OCR.space API (for text extraction from PDFs)
# Get from: https://ocr.space/ocrapi
OCR_API_KEY=your_ocr_space_api_key
OCR_API=https://api.ocr.space/parse/image

# ImageKit (for cloud file storage - production)
# Get from: https://imagekit.io/
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_team_id
